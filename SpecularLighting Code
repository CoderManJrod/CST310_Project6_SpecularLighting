float camX = 0.0f, camY = 2.5f, camZ = 10.0f;

GLuint shaderProgram = 0;
GLuint VAO = 0, VBO = 0, EBO = 0;

GLint uModel = -1, uView = -1, uProj = -1;
GLint uLightPos = -1, uViewPos = -1;
GLint uLightColor = -1, uObjectColor = -1;
GLint uShininess = -1;

int winW = 1000, winH = 700;

std::vector<float> shininessVals = {2, 4, 8, 16, 32, 64, 128, 256};

std::string typed = "";
bool singleMode = false;
float selectedShininess = 32.0f;


void matIdentity(float m[16]) {
    for (int i = 0; i < 16; i++) m[i] = 0.0f;
    m[0] = m[5] = m[10] = m[15] = 1.0f;
}
void matMul(const float a[16], const float b[16], float out[16]) {
    float r[16];
    for (int c = 0; c < 4; c++)
        for (int r0 = 0; r0 < 4; r0++)
            r[c*4+r0] = a[0*4+r0]*b[c*4+0]+a[1*4+r0]*b[c*4+1]+
                        a[2*4+r0]*b[c*4+2]+a[3*4+r0]*b[c*4+3];
    for (int i = 0; i < 16; i++) out[i] = r[i];
}
void matTranslate(float m[16], float x, float y, float z) {
    matIdentity(m); m[12]=x; m[13]=y; m[14]=z;
}
void matScale(float m[16], float sx, float sy, float sz) {
    matIdentity(m); m[0]=sx; m[5]=sy; m[10]=sz;
}
void matPerspective(float fovyDeg, float aspect, float zNear, float zFar, float out[16]) {
    float fovy = fovyDeg*(float)M_PI/180.0f;
    float f = 1.0f/tanf(fovy/2.0f);
    for (int i=0;i<16;i++) out[i]=0.0f;
    out[0]=f/aspect; out[5]=f;
    out[10]=(zFar+zNear)/(zNear-zFar); out[11]=-1.0f;
    out[14]=(2.0f*zFar*zNear)/(zNear-zFar);
}
void vecNormalize(float v[3]) {
    float len=sqrtf(v[0]*v[0]+v[1]*v[1]+v[2]*v[2]);
    if(len>1e-6f){v[0]/=len;v[1]/=len;v[2]/=len;}
}
void vecCross(const float a[3], const float b[3], float out[3]) {
    out[0]=a[1]*b[2]-a[2]*b[1]; out[1]=a[2]*b[0]-a[0]*b[2]; out[2]=a[0]*b[1]-a[1]*b[0];
}
void matLookAt(float eyeX,float eyeY,float eyeZ,
               float cx,float cy,float cz,
               float upX,float upY,float upZ, float out[16]) {
    float f[3]={cx-eyeX,cy-eyeY,cz-eyeZ}; vecNormalize(f);
    float up[3]={upX,upY,upZ}; vecNormalize(up);
    float s[3]; vecCross(f,up,s); vecNormalize(s);
    float u[3]; vecCross(s,f,u);
    matIdentity(out);
    out[0]=s[0];out[4]=s[1];out[8]=s[2];
    out[1]=u[0];out[5]=u[1];out[9]=u[2];
    out[2] = -f[0];out[6] = -f[1];out[10] = -f[2];

    // Missing translation — this is what hid all the cubes
    out[12] = -( s[0]*eyeX + s[1]*eyeY + s[2]*eyeZ );
    out[13] = -( u[0]*eyeX + u[1]*eyeY + u[2]*eyeZ );
    out[14] =  ( f[0]*eyeX + f[1]*eyeY + f[2]*eyeZ );
}


GLuint compileShader(GLenum type, const char* src) {
    GLuint sh = glCreateShader(type);
    glShaderSource(sh, 1, &src, nullptr);
    glCompileShader(sh);
    GLint ok=0; glGetShaderiv(sh,GL_COMPILE_STATUS,&ok);
    if(!ok){ char log[1024]; glGetShaderInfoLog(sh,1024,nullptr,log); printf("Shader error: %s\n",log); }
    return sh;
}

void createShaders() {
    // Vertex shader — unchanged
    const char* vs = R"GLSL(
#version 330 core
layout (location=0) in vec3 aPos;
layout (location=1) in vec3 aNormal;

out vec3 FragPos;
out vec3 Normal;

uniform mat4 model;
uniform mat4 view;
uniform mat4 projection;

void main(){
    vec4 worldPos = model * vec4(aPos, 1.0);
    FragPos = worldPos.xyz;
    Normal = mat3(transpose(inverse(model))) * aNormal;
    gl_Position = projection * view * worldPos;
}
)GLSL";

    const char* fs = R"GLSL(
#version 330 core
in vec3 FragPos;
in vec3 Normal;

out vec4 FragColor;

uniform vec3  lightPos;
uniform vec3  viewPos;
uniform vec3  lightColor;
uniform vec3  objectColor;
uniform float shininess;

void main(){
    // Ambient Lighting
    float ambientStrength = 0.10;
    vec3 ambient = ambientStrength * lightColor;

    // --- Diffuse (warm boost for gradient)
    vec3  norm     = normalize(Normal);
    vec3  lightDir = normalize(lightPos - FragPos);
    float diff     = max(dot(norm, lightDir), 0.0);
    vec3  diffuse  = diff * 1.15 * lightColor;

    // Specular (Blinn-Phong with shininess-scaled strength)
    float specularStrength = 0.30 + 0.70 * (shininess / 256.0);
    vec3  viewDir  = normalize(viewPos - FragPos);
    vec3  halfDir  = normalize(lightDir + viewDir);   // Blinn halfway vector
    float spec     = pow(max(dot(norm, halfDir), 0.0), shininess);
    vec3  specular = specularStrength * spec * lightColor;

    vec3 result = (ambient + diffuse + specular) * objectColor;
    FragColor   = vec4(result, 1.0);
}
)GLSL";

    GLuint v = compileShader(GL_VERTEX_SHADER,   vs);
    GLuint f = compileShader(GL_FRAGMENT_SHADER, fs);
    shaderProgram = glCreateProgram();
    glAttachShader(shaderProgram,v); glAttachShader(shaderProgram,f);
    glLinkProgram(shaderProgram);
    GLint ok=0; glGetProgramiv(shaderProgram,GL_LINK_STATUS,&ok);
    if(!ok){ char log[1024]; glGetProgramInfoLog(shaderProgram,1024,nullptr,log); printf("Link error: %s\n",log); }
    glDeleteShader(v); glDeleteShader(f);

    uModel=glGetUniformLocation(shaderProgram,"model");
    uView =glGetUniformLocation(shaderProgram,"view");
    uProj =glGetUniformLocation(shaderProgram,"projection");
    uLightPos   =glGetUniformLocation(shaderProgram,"lightPos");
    uViewPos    =glGetUniformLocation(shaderProgram,"viewPos");
    uLightColor =glGetUniformLocation(shaderProgram,"lightColor");
    uObjectColor=glGetUniformLocation(shaderProgram,"objectColor");
    uShininess  =glGetUniformLocation(shaderProgram,"shininess");
}

float cubeVerts[] = {
    -0.5f,-0.5f,-0.5f, 0,0,-1,  0.5f,-0.5f,-0.5f, 0,0,-1,
     0.5f, 0.5f,-0.5f, 0,0,-1, -0.5f, 0.5f,-0.5f, 0,0,-1,
    -0.5f,-0.5f, 0.5f, 0,0, 1,  0.5f,-0.5f, 0.5f, 0,0, 1,
     0.5f, 0.5f, 0.5f, 0,0, 1, -0.5f, 0.5f, 0.5f, 0,0, 1,
    -0.5f,-0.5f,-0.5f, 0,-1,0,  0.5f,-0.5f,-0.5f, 0,-1,0,
     0.5f,-0.5f, 0.5f, 0,-1,0, -0.5f,-0.5f, 0.5f, 0,-1,0,
    -0.5f, 0.5f,-0.5f, 0, 1,0,  0.5f, 0.5f,-0.5f, 0, 1,0,
     0.5f, 0.5f, 0.5f, 0, 1,0, -0.5f, 0.5f, 0.5f, 0, 1,0,
    -0.5f,-0.5f,-0.5f,-1,0,0, -0.5f,-0.5f, 0.5f,-1,0,0,
    -0.5f, 0.5f, 0.5f,-1,0,0, -0.5f, 0.5f,-0.5f,-1,0,0,
     0.5f,-0.5f,-0.5f, 1,0,0,  0.5f,-0.5f, 0.5f, 1,0,0,
     0.5f, 0.5f, 0.5f, 1,0,0,  0.5f, 0.5f,-0.5f, 1,0,0
};
unsigned int cubeIdx[] = {
    0,1,2,2,3,0, 4,5,6,6,7,4, 8,9,10,10,11,8,
    12,13,14,14,15,12, 16,17,18,18,19,16, 20,21,22,22,23,20
};

void createCubeMesh() {
    glGenVertexArrays(1,&VAO); glGenBuffers(1,&VBO); glGenBuffers(1,&EBO);
    glBindVertexArray(VAO);
    glBindBuffer(GL_ARRAY_BUFFER,VBO);
    glBufferData(GL_ARRAY_BUFFER,sizeof(cubeVerts),cubeVerts,GL_STATIC_DRAW);
    glBindBuffer(GL_ELEMENT_ARRAY_BUFFER,EBO);
    glBufferData(GL_ELEMENT_ARRAY_BUFFER,sizeof(cubeIdx),cubeIdx,GL_STATIC_DRAW);
    glVertexAttribPointer(0,3,GL_FLOAT,GL_FALSE,6*sizeof(float),(void*)0);
    glEnableVertexAttribArray(0);
    glVertexAttribPointer(1,3,GL_FLOAT,GL_FALSE,6*sizeof(float),(void*)(3*sizeof(float)));
    glEnableVertexAttribArray(1);
    glBindVertexArray(0);
}


void drawText2D(float x, float y, const std::string& s) {
    glUseProgram(0);
    glMatrixMode(GL_PROJECTION); glPushMatrix(); glLoadIdentity();
    gluOrtho2D(0,winW,0,winH);
    glMatrixMode(GL_MODELVIEW); glPushMatrix(); glLoadIdentity();
    glDisable(GL_DEPTH_TEST);
    glColor3f(0.1f,0.1f,0.1f);
    glRasterPos2f(x,y);
    for(char c:s) glutBitmapCharacter(GLUT_BITMAP_HELVETICA_18,c);
    glEnable(GL_DEPTH_TEST);
    glPopMatrix(); glMatrixMode(GL_PROJECTION); glPopMatrix(); glMatrixMode(GL_MODELVIEW);
    glUseProgram(shaderProgram);
}

void drawCubeAt(float x,float y,float z,float s,float shin) {
    float T[16],S[16],M[16];
    matTranslate(T,x,y,z); matScale(S,s,s,s); matMul(T,S,M);
    glUniformMatrix4fv(uModel,1,GL_FALSE,M);
    glUniform1f(uShininess,shin);
    glBindVertexArray(VAO);
    glDrawElements(GL_TRIANGLES,36,GL_UNSIGNED_INT,0);
    glBindVertexArray(0);
}


void display() {
    glClear(GL_COLOR_BUFFER_BIT | GL_DEPTH_BUFFER_BIT);
    glUseProgram(shaderProgram);

    float V[16],P[16];
    matLookAt(camX,camY,camZ, 0.0f,0.0f,0.0f, 0,1,0, V);
    matPerspective(45.0f,(float)winW/(float)winH,0.1f,100.0f,P);

    glUniformMatrix4fv(uView,1,GL_FALSE,V);
    glUniformMatrix4fv(uProj,1,GL_FALSE,P);

    glUniform3f(uLightPos,    3.0f, 5.0f, 8.0f);
    glUniform3f(uViewPos,     camX, camY, camZ);
    glUniform3f(uLightColor,  1.0f, 1.0f, 1.0f);

    
    glUniform3f(uObjectColor, 0.90f, 0.45f, 0.25f);

    if (!singleMode) {
        float startX=-4.5f, startYTop=1.5f, startYBot=-1.5f, stepX=3.0f, z=0.0f, size=1.2f;
        for(int i=0;i<4;i++){
            drawCubeAt(startX+i*stepX, startYTop, z, size, shininessVals[i]);
            drawText2D(160.0f+i*220.0f, 390.0f, std::to_string((int)shininessVals[i]));
        }
        for(int i=0;i<4;i++){
            drawCubeAt(startX+i*stepX, startYBot, z, size, shininessVals[i+4]);
            drawText2D(160.0f+i*220.0f, 110.0f, std::to_string((int)shininessVals[i+4]));
        }
        drawText2D(20,winH-30,"Type shininess (2..256) + Enter to view one cube. Press G for grid.");
        drawText2D(20,winH-55,"Input: "+typed);
    } else {
        drawCubeAt(0.0f,0.0f,0.0f, 2.2f, selectedShininess);
        drawText2D(20,winH-30,"Single cube mode. Shininess = "+std::to_string((int)selectedShininess));
        drawText2D(20,winH-55,"Press G to return to grid. Input: "+typed);
    }

    glutSwapBuffers();
}


bool isAllowedShininess(int v){ for(float s:shininessVals) if((int)s==v) return true; return false; }

void keyboard(unsigned char key,int,int){
    if(key==27) exit(0);
    if(key=='g'||key=='G'){ singleMode=false; typed.clear(); glutPostRedisplay(); return; }
    if(key==8||key==127){ if(!typed.empty()) typed.pop_back(); glutPostRedisplay(); return; }
    if(key==13||key==10){
        if(!typed.empty()){
            int v=atoi(typed.c_str());
            if(isAllowedShininess(v)){ selectedShininess=(float)v; singleMode=true; }
            else typed="";
        }
        glutPostRedisplay(); return;
    }
    if(key>='0'&&key<='9'){ if(typed.size()<3) typed.push_back((char)key); glutPostRedisplay(); }
}

void reshape(int w,int h){ winW=(w<1)?1:w; winH=(h<1)?1:h; glViewport(0,0,winW,winH); }

void initGL(){
    glEnable(GL_DEPTH_TEST);
    glClearColor(0.90f,0.93f,0.98f,1.0f);
    glewExperimental=GL_TRUE;
    if(glewInit()!=GLEW_OK){ fprintf(stderr,"GLEW init failed\n"); exit(1); }
    createShaders();
    createCubeMesh();
}

int main(int argc,char** argv){
    glutInit(&argc,argv);
    glutInitDisplayMode(GLUT_DOUBLE|GLUT_RGB|GLUT_DEPTH);
    glutInitWindowSize(winW,winH);
    glutCreateWindow("Shininess Values (Specular Highlight Demo)");
    initGL();
    glutDisplayFunc(display);
    glutReshapeFunc(reshape);
    glutKeyboardFunc(keyboard);
    glutMainLoop();
    return 0;
}
